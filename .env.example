# =============================================================================
# Next Secure Auth Starter — environment template
# Copy to apps/starter/.env.local (see README.md)
# Full reference: docs/configuration-reference.md
# =============================================================================

# --- App ---
# Public base URL for links and WebAuthn origin fallback
APP_BASE_URL=http://localhost:3001
# Display name shown in UI and emails
APP_NAME="Next Secure Auth Starter"
# URL-safe identifier for the app
APP_SLUG=next-secure-auth-starter
NODE_ENV=development

# --- Database ---
# PostgreSQL connection string (matches docker-compose postgres service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/next_secure_auth_starter

# --- Auth / NextAuth ---
# Must match APP_BASE_URL in local dev
NEXTAUTH_URL=http://localhost:3001
# Session signing secret — long random string (required in production)
NEXTAUTH_SECRET=replace-with-long-random-secret
# Post-login redirect when not overridden in code
AUTH_AFTER_LOGIN_PATH=/dashboard
# Post-logout redirect
AUTH_AFTER_LOGOUT_PATH=/login

# --- OAuth — Google ---
# Legacy GOOGLE_* names are also supported by the starter env mapper
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# --- OAuth — Apple ---
# Legacy APPLE_* names are also supported
AUTH_APPLE_CLIENT_ID=
AUTH_APPLE_CLIENT_SECRET=
# Apple Sign In JWT signing (starter email/OAuth module; not passed to createSecureAuth)
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- OAuth — GitHub ---
# Legacy GITHUB_* names are also supported by the env mapper
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# --- OAuth — Microsoft ---
# Legacy AUTH_MICROSOFT_ID / AUTH_AZURE_AD_* aliases supported
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_TENANT_ID=common

# --- Email ---
# console | smtp — starter email module only (not createSecureAuth)
EMAIL_PROVIDER=console
EMAIL_FROM="Next Secure Auth Starter <noreply@localhost>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# --- WebAuthn / Passkeys ---
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Next Secure Auth Starter"
WEBAUTHN_ORIGIN=http://localhost:3001

# --- Two-factor ---
# 32-byte base64 key for encrypting TOTP secrets at rest (required in production)
TWO_FACTOR_SECRET_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# --- Sessions ---
# Maximum session lifetime in seconds (default: 30 days)
AUTH_SESSION_MAX_AGE_SECONDS=2592000
# How often to update session last-used timestamp (alias: AUTH_SESSION_PING_INTERVAL_SECONDS)
AUTH_SESSION_LAST_USED_UPDATE_SECONDS=300
# When true, each login revokes all other active sessions for the user
AUTH_SINGLE_ACTIVE_SESSION=false
# How often (seconds) revoked browsers poll and sign out locally (5–300, default 10)
AUTH_SESSION_REVOCATION_POLL_SECONDS=10

# --- Password policy ---
# off | warn | enforce
AUTH_PASSWORD_POLICY_ENFORCEMENT=warn
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_UPPERCASE=false
AUTH_PASSWORD_REQUIRE_LOWERCASE=false
AUTH_PASSWORD_REQUIRE_NUMBER=false
AUTH_PASSWORD_REQUIRE_SYMBOL=false
AUTH_PASSWORD_BLOCK_COMMON_PASSWORDS=true
AUTH_PASSWORD_MIN_SCORE=2
# Password strength feedback placement on register/reset forms: above | below
AUTH_PASSWORD_STRENGTH_POSITION=above

# --- Account / email verification ---
EMAIL_VERIFICATION_SEND_ON_REGISTER=true
EMAIL_VERIFICATION_REQUIRE_BEFORE_SIGN_IN=false

# --- Rate limiting ---
# memory | postgres — rate limit policy thresholds are fixed in the package
AUTH_RATE_LIMIT_STORE=memory

# --- CAPTCHA / Cloudflare Turnstile ---
AUTH_CAPTCHA_ENABLED=false
AUTH_CAPTCHA_PROVIDER=turnstile
AUTH_CAPTCHA_TURNSTILE_SITE_KEY=
AUTH_CAPTCHA_TURNSTILE_SECRET_KEY=
AUTH_CAPTCHA_REGISTER_ENABLED=false
AUTH_CAPTCHA_LOGIN_ENABLED=false

# --- Cookies ---
# When unset, starter defaults to true in production (NODE_ENV=production)
AUTH_COOKIE_SECURE=

# --- Debug ---
# Server-side auth flow trace logging
AUTH_TRACE=false
# Client-visible trace flag (starter middleware/UI; not createSecureAuth)
NEXT_PUBLIC_AUTH_DEBUG_TRACE=false
