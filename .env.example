# App
APP_BASE_URL=http://localhost:3002
NODE_ENV=development

# Auth.js / NextAuth
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=replace-with-long-random-secret

# Database (matches docker-compose postgres service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/next_secure_auth_starter

# Email
# console | smtp
EMAIL_PROVIDER=console
EMAIL_FROM="Next Secure Auth Starter <noreply@localhost>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# OAuth — Google (GOOGLE_* is what auth-options reads today)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# OAuth — Microsoft (AUTH_MICROSOFT_* aliases supported; see microsoft-provider-config.ts)
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=
AUTH_MICROSOFT_TENANT_ID=common

# WebAuthn / passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Next Secure Auth Starter"
WEBAUTHN_ORIGIN=http://localhost:3002

# TOTP / two-factor secret encryption at rest
TWO_FACTOR_SECRET_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Account policy — password strength and email verification
# Password strength: off | warn | enforce
PASSWORD_POLICY_ENFORCEMENT=warn
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_LOWERCASE=false
PASSWORD_REQUIRE_NUMBER=false
PASSWORD_REQUIRE_SYMBOL=false
PASSWORD_BLOCK_COMMON_PASSWORDS=true
PASSWORD_MIN_SCORE=2

# Send a verification link after email/password registration
EMAIL_VERIFICATION_SEND_ON_REGISTER=true
# When true, email/password and passkey sign-in require a verified email first
EMAIL_VERIFICATION_REQUIRE_BEFORE_SIGN_IN=false

# Rate limiting store: memory | postgres
RATE_LIMIT_STORE=memory

# Auth debugging — logs safe auth flow steps to the server console and /api/auth/login/trace
AUTH_DEBUG_TRACE=false
NEXT_PUBLIC_AUTH_DEBUG_TRACE=false

# Session tuning
SESSION_LAST_USED_UPDATE_INTERVAL_SECONDS=300
