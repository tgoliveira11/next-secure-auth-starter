{
  "name": "@tgoliveira/secure-auth",
  "version": "0.1.15-internal",
  "description": "Opinionated Next.js + Drizzle + PostgreSQL authentication package (experimental internal release)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tgoliveira11/next-secure-auth-starter.git",
    "directory": "packages/secure-auth"
  },
  "bugs": {
    "url": "https://github.com/tgoliveira11/next-secure-auth-starter/issues"
  },
  "homepage": "https://github.com/tgoliveira11/next-secure-auth-starter#readme",
  "keywords": [
    "nextjs",
    "authentication",
    "drizzle",
    "postgresql",
    "passkeys",
    "oauth",
    "2fa"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "require": "./dist/next/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./react/client": {
      "types": "./dist/react/client.d.ts",
      "import": "./dist/react/client.js",
      "require": "./dist/react/client.cjs"
    },
    "./drizzle/schema": {
      "types": "./dist/drizzle/schema.d.ts",
      "import": "./dist/drizzle/schema.js",
      "require": "./dist/drizzle/schema.cjs"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "import": "./dist/email/index.js",
      "require": "./dist/email/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./client/password-policy": {
      "types": "./dist/client/password-policy.d.ts",
      "import": "./dist/client/password-policy.js",
      "require": "./dist/client/password-policy.cjs"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "migrations",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.core.config.ts && tsup --config tsup.react-client.config.ts && tsup --config tsup.ui.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'Package lint: configure eslint in 0.2.x'",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2",
    "next": "^16.0.0",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.1.0",
    "@simplewebauthn/server": "^13.1.1",
    "bcryptjs": "^3.0.2",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "server-only": "^0.0.1",
    "uuid": "^11.1.1",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "react": "^19.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
