# Copy to .env.local — never commit real values

APP_BASE_URL=http://localhost:3001
APP_NAME=Next Secure Auth Starter
APP_SLUG=next-secure-auth-starter
NODE_ENV=development

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=replace-with-long-random-secret

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/next_secure_auth_starter

EMAIL_PROVIDER=console
EMAIL_FROM="Next Secure Auth Starter <noreply@localhost>"

WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3001

TWO_FACTOR_SECRET_ENCRYPTION_KEY=replace-with-32-byte-base64-key
