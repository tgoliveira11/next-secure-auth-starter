# =============================================================================
# @tgoliveira/secure-auth — consumer-demo environment template
# Copy to .env.local and fill in the values.
#
# Every variable listed here is read by buildSecureAuthConfigFromEnv() in
# src/lib/env/secure-auth-from-env.ts, which maps them to createSecureAuth(config).
# =============================================================================

# -----------------------------------------------------------------------------
# App identity
# Used for: app.name, app.slug, app.baseUrl, default redirect paths
# APP_BASE_URL / NEXTAUTH_URL are interchangeable — both set the canonical URL.
# -----------------------------------------------------------------------------
APP_BASE_URL=http://localhost:3002
APP_NAME="Consumer Demo"
APP_SLUG=consumer-demo
NEXTAUTH_URL=http://localhost:3002

# -----------------------------------------------------------------------------
# Database
# Drizzle + postgres.js — must point to a database with the package schema applied.
# Run: npx drizzle-kit push in this directory after setting this.
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5433/consumer_demo_auth

# -----------------------------------------------------------------------------
# NextAuth core
# NEXTAUTH_SECRET: any long random string (openssl rand -base64 32)
# TWO_FACTOR_SECRET_ENCRYPTION_KEY: exactly 32-byte base64 (openssl rand -base64 32)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=replace-with-long-random-secret
TWO_FACTOR_SECRET_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# -----------------------------------------------------------------------------
# Auth redirect behaviour
# After login → AUTH_AFTER_LOGIN_PATH (default: /dashboard)
# After logout → AUTH_AFTER_LOGOUT_PATH (default: /login)
# Redirect authenticated users away from guest pages (login, register, etc.)
# AUTH_AUTHENTICATED_REDIRECT_PATH: where to send them; falls back to after-login path
# -----------------------------------------------------------------------------
AUTH_AFTER_LOGIN_PATH=/dashboard
AUTH_AFTER_LOGOUT_PATH=/login
AUTH_REDIRECT_AUTHENTICATED_FROM_GUEST_PAGES=true
AUTH_AUTHENTICATED_REDIRECT_PATH=/dashboard

# -----------------------------------------------------------------------------
# Email
# EMAIL_FROM: sender address shown in all outgoing emails.
# The email provider itself is wired in src/lib/secure-auth.ts (console in dev).
# For production, replace consoleEmailProvider with a real transport.
# -----------------------------------------------------------------------------
EMAIL_FROM="Consumer Demo <noreply@localhost>"

# -----------------------------------------------------------------------------
# OAuth providers — leave blank to disable a provider entirely
# Microsoft aliases: AUTH_AZURE_AD_ID / AUTH_AZURE_AD_SECRET also accepted.
# AUTH_MICROSOFT_TENANT_ID: "common" = any org/personal account (default)
# -----------------------------------------------------------------------------
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

AUTH_APPLE_CLIENT_ID=
AUTH_APPLE_CLIENT_SECRET=

AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_TENANT_ID=common

# -----------------------------------------------------------------------------
# WebAuthn / Passkeys
# WEBAUTHN_RP_ID: registrable domain suffix of your app (e.g. example.com)
# WEBAUTHN_ORIGIN: full origin the browser uses — must match the actual URL
# -----------------------------------------------------------------------------
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Consumer Demo"
WEBAUTHN_ORIGIN=http://localhost:3002

# -----------------------------------------------------------------------------
# Sessions
# MAX_AGE_SECONDS: how long a session token lives (default 30 days = 2592000)
# LAST_USED_UPDATE_SECONDS: how often "last seen" is refreshed (default 5 min)
# SINGLE_ACTIVE_SESSION: when true, login revokes all other sessions for the user
# REVOCATION_POLL_SECONDS: how often the client polls for remote revocation
#   (only relevant when SINGLE_ACTIVE_SESSION=true; ignored otherwise)
# -----------------------------------------------------------------------------
AUTH_SESSION_MAX_AGE_SECONDS=2592000
AUTH_SESSION_LAST_USED_UPDATE_SECONDS=300
AUTH_SINGLE_ACTIVE_SESSION=false
AUTH_SESSION_REVOCATION_POLL_SECONDS=10

# -----------------------------------------------------------------------------
# Password policy
# ENFORCEMENT: off | warn | enforce
#   off    — no checks at all
#   warn   — strength bar shown, form always submits
#   enforce — blocks submission below minimum score
# MIN_SCORE: 0–4 zxcvbn score required when enforcement=enforce (default 2)
# STRENGTH_POSITION: above | below — where the strength bar appears in the form
# BLOCK_COMMON_PASSWORDS: rejects passwords in the built-in common list
# AUTH_PASSWORD_HIBP_ENABLED: check against Have I Been Pwned at registration
#   (opt-in — disabled by default; requires outbound HTTPS to api.pwnedpasswords.com)
#   Alias: AUTH_PASSWORD_CHECK_BREACHED also accepted
# -----------------------------------------------------------------------------
AUTH_PASSWORD_POLICY_ENFORCEMENT=warn
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_UPPERCASE=false
AUTH_PASSWORD_REQUIRE_LOWERCASE=false
AUTH_PASSWORD_REQUIRE_NUMBER=false
AUTH_PASSWORD_REQUIRE_SYMBOL=false
AUTH_PASSWORD_BLOCK_COMMON_PASSWORDS=true
AUTH_PASSWORD_MIN_SCORE=2
AUTH_PASSWORD_STRENGTH_POSITION=above
AUTH_PASSWORD_HIBP_ENABLED=false

# -----------------------------------------------------------------------------
# Account / email verification
# SEND_ON_REGISTER: send a verification email immediately after registration
# REQUIRE_BEFORE_SIGN_IN: block login until email is verified
# REQUIRE_FOR_ACCOUNT_APIS: reject sensitive account API calls for unverified emails
# -----------------------------------------------------------------------------
EMAIL_VERIFICATION_SEND_ON_REGISTER=true
EMAIL_VERIFICATION_REQUIRE_BEFORE_SIGN_IN=false
EMAIL_VERIFICATION_REQUIRE_FOR_ACCOUNT_APIS=true

# -----------------------------------------------------------------------------
# API security — same-origin protection
# Validates the Origin / Referer header on mutating auth endpoints.
# AUTH_ALLOWED_ORIGINS: comma-separated list of additional allowed origins
#   (app.baseUrl and webauthn.origin are always allowed automatically)
# -----------------------------------------------------------------------------
AUTH_SAME_ORIGIN_PROTECTION_ENABLED=true
# AUTH_ALLOWED_ORIGINS=https://app.example.com,https://preview.example.com

# -----------------------------------------------------------------------------
# Rate limiting
# STORE: memory (default, single-process) | postgres (multi-instance safe)
# -----------------------------------------------------------------------------
AUTH_RATE_LIMIT_STORE=memory

# -----------------------------------------------------------------------------
# CAPTCHA — Cloudflare Turnstile (only provider supported today)
# AUTH_CAPTCHA_ENABLED: master switch
# AUTH_CAPTCHA_REGISTER_ENABLED / AUTH_CAPTCHA_LOGIN_ENABLED: per-page control
#   (only effective when the master switch is on)
# Obtain keys at dash.cloudflare.com → Turnstile
# -----------------------------------------------------------------------------
AUTH_CAPTCHA_ENABLED=false
AUTH_CAPTCHA_TURNSTILE_SITE_KEY=
AUTH_CAPTCHA_TURNSTILE_SECRET_KEY=
AUTH_CAPTCHA_REGISTER_ENABLED=false
AUTH_CAPTCHA_LOGIN_ENABLED=false

# -----------------------------------------------------------------------------
# Cookies
# AUTH_COOKIE_SECURE: true in production (HTTPS only). Defaults to true when
#   NODE_ENV=production; leave blank to use that automatic behaviour.
# -----------------------------------------------------------------------------
AUTH_COOKIE_SECURE=

# -----------------------------------------------------------------------------
# Debug — never expose trace routes in production
# AUTH_TRACE: enables verbose auth trace logging to the server console
# AUTH_DEBUG_EXPOSE_TRACE_ROUTE: serves GET /api/auth/login/trace (for local debugging only)
#   Alias: AUTH_DEBUG_TRACE also accepted for AUTH_TRACE
# -----------------------------------------------------------------------------
AUTH_TRACE=false
AUTH_DEBUG_EXPOSE_TRACE_ROUTE=false

# -----------------------------------------------------------------------------
# v0.2 feature flags — all opt-in, disabled by default
# Enabling any of these does not require a schema migration.
#
# AUTH_MAGIC_LINK_ENABLED: passwordless email login via one-time link (15 min TTL)
# AUTH_SECURITY_NOTIFICATIONS_ENABLED: email alerts on login from new device,
#   password change, 2FA disable, email change, magic link use
# AUTH_PASSWORD_HIBP_ENABLED: breach detection via HIBP k-anonymity API at registration
# -----------------------------------------------------------------------------
AUTH_MAGIC_LINK_ENABLED=false
AUTH_SECURITY_NOTIFICATIONS_ENABLED=false
AUTH_PASSWORD_HIBP_ENABLED=false

# -----------------------------------------------------------------------------
# v0.3 feature flags — all opt-in, disabled by default
#
# Admin panel
# AUTH_ADMIN_ENABLED: enable the built-in admin UI at AUTH_ADMIN_PATH (default /admin)
# ADMIN_BOOTSTRAP_EMAIL: promote this user to admin on first start when no admin exists
# AUTH_ADMIN_CONFIG_CACHE_TTL_SECONDS: seconds to cache DB config overrides (default 60)
#
# Progressive account lockout
# AUTH_ACCOUNT_LOCKOUT_ENABLED: graduate failed logins through freeze → permanent lock
#
# Invite system
# AUTH_INVITES_ENABLED: enable invite codes and/or waitlist approval
# AUTH_INVITES_REQUIRE_APPROVAL: new accounts start pending until admin approves
# AUTH_INVITES_REQUIRE_CODE: registration requires a valid invite code
# AUTH_INVITES_DEFAULT_QUOTA: invite codes given to each approved user (default 0)
# AUTH_INVITES_CODE_EXPIRY_DAYS: days before an invite code expires (default 30)
#
# Machine-to-machine auth
# AUTH_API_KEYS_ENABLED: enable API key auth for server-to-server requests
# AUTH_API_KEYS_DEFAULT_EXPIRY_DAYS: key expiry in days (default 365; 0 = never)
#
# User profile
# AUTH_PROFILE_ENABLED: enable display name, avatar, and bio (pulled from OAuth on login)
# AUTH_PROFILE_ALLOW_AVATAR_UPLOAD: allow avatar image uploads (requires uploadHandler)
# -----------------------------------------------------------------------------
AUTH_ADMIN_ENABLED=false
AUTH_ADMIN_PATH=/admin
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
AUTH_ADMIN_CONFIG_CACHE_TTL_SECONDS=60

AUTH_ACCOUNT_LOCKOUT_ENABLED=false

AUTH_INVITES_ENABLED=false
AUTH_INVITES_REQUIRE_APPROVAL=false
AUTH_INVITES_REQUIRE_CODE=false
AUTH_INVITES_DEFAULT_QUOTA=0
AUTH_INVITES_CODE_EXPIRY_DAYS=30

AUTH_API_KEYS_ENABLED=false
AUTH_API_KEYS_DEFAULT_EXPIRY_DAYS=365

AUTH_PROFILE_ENABLED=false
AUTH_PROFILE_ALLOW_AVATAR_UPLOAD=false
