# =============================================================================
# @secure-auth/consumer-demo — environment template
# Copy to .env.local in this directory
# Full reference: docs/configuration-reference.md
# =============================================================================

# --- App ---
APP_BASE_URL=http://localhost:3002
APP_NAME="Consumer Demo"
APP_SLUG=consumer-demo
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5433/consumer_demo_auth

# --- Auth / NextAuth ---
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=replace-with-long-random-secret
AUTH_AFTER_LOGIN_PATH=/dashboard
AUTH_AFTER_LOGOUT_PATH=/login
AUTH_REDIRECT_AUTHENTICATED_FROM_GUEST_PAGES=true
AUTH_AUTHENTICATED_REDIRECT_PATH=/dashboard

# --- OAuth — Google ---
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# --- OAuth — Apple ---
AUTH_APPLE_CLIENT_ID=
AUTH_APPLE_CLIENT_SECRET=

# --- OAuth — GitHub ---
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# --- OAuth — Microsoft ---
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_TENANT_ID=common

# --- Email ---
# console provider is wired in code; from address is configurable
EMAIL_FROM="Consumer Demo <noreply@localhost>"

# --- WebAuthn / Passkeys ---
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Consumer Demo"
WEBAUTHN_ORIGIN=http://localhost:3002

# --- Two-factor ---
TWO_FACTOR_SECRET_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# --- Sessions ---
AUTH_SESSION_MAX_AGE_SECONDS=2592000
AUTH_SESSION_LAST_USED_UPDATE_SECONDS=300
AUTH_SINGLE_ACTIVE_SESSION=false
AUTH_SESSION_REVOCATION_POLL_SECONDS=10

# --- Password policy ---
AUTH_PASSWORD_POLICY_ENFORCEMENT=warn
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_UPPERCASE=false
AUTH_PASSWORD_REQUIRE_LOWERCASE=false
AUTH_PASSWORD_REQUIRE_NUMBER=false
AUTH_PASSWORD_REQUIRE_SYMBOL=false
AUTH_PASSWORD_BLOCK_COMMON_PASSWORDS=true
AUTH_PASSWORD_MIN_SCORE=2
AUTH_PASSWORD_STRENGTH_POSITION=above

# --- Account / email verification ---
EMAIL_VERIFICATION_SEND_ON_REGISTER=true
EMAIL_VERIFICATION_REQUIRE_BEFORE_SIGN_IN=false

# --- Rate limiting ---
AUTH_RATE_LIMIT_STORE=memory

# --- CAPTCHA / Cloudflare Turnstile ---
AUTH_CAPTCHA_ENABLED=false
AUTH_CAPTCHA_PROVIDER=turnstile
AUTH_CAPTCHA_TURNSTILE_SITE_KEY=
AUTH_CAPTCHA_TURNSTILE_SECRET_KEY=
AUTH_CAPTCHA_REGISTER_ENABLED=false
AUTH_CAPTCHA_LOGIN_ENABLED=false

# --- Cookies ---
AUTH_COOKIE_SECURE=

# --- Debug ---
AUTH_TRACE=false
