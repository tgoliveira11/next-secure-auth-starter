{
  "name": "@secure-auth/dev-harness",
  "version": "0.4.1",
  "private": true,
  "description": "Integration harness for @tgoliveira/secure-auth",
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build",
    "start": "next start -p 3003",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "postinstall": "node scripts/copy-swagger-ui.mjs"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.1.0",
    "@simplewebauthn/server": "^13.1.1",
    "@tgoliveira/secure-auth": "file:../../packages/secure-auth",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "postgres": "^3.4.7",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "swagger-ui-dist": "^5.11.0",
    "uuid": "^11.1.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.15.29",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "axe-core": "^4.12.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.9",
    "happy-dom": "^20.10.3",
    "jest-axe": "^10.0.0",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
